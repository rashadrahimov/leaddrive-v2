# Güvən Technology — Production (.env on server: /opt/leaddrive-v2/.env)
# Copy this to the server and fill in secrets

# Database
DATABASE_URL="postgresql://leaddrive:PASSWORD@localhost:5432/leaddrive"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="GENERATE_WITH_openssl_rand_-base64_32"
NEXTAUTH_URL="https://app.leaddrivecrm.org"

# Domain URLs
NEXT_PUBLIC_APP_URL="https://app.leaddrivecrm.org"
NEXT_PUBLIC_MARKETING_URL="https://leaddrivecrm.org"
COOKIE_DOMAIN=".leaddrivecrm.org"
NEXT_PUBLIC_CONTACT_EMAIL="info@leaddrivecrm.org"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# AI
ANTHROPIC_API_KEY=""

# WhatsApp
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Sentry
SENTRY_DSN=""

# Telegram notifications
TELEGRAM_BOT_TOKEN=""
TELEGRAM_FINANCE_CHAT_ID=""
