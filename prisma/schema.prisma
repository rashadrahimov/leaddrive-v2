// LeadDrive CRM v2.0 — Prisma Schema
// Multi-tenant: ALL models (except Organization) have organizationId

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ORGANIZATION & AUTH
// ═══════════════════════════════════════════════════

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("starter") // starter, professional, enterprise
  addons      String[] @default([])
  modules     Json     @default("{}")
  logo        String?
  settings    Json     @default("{}")
  maxUsers    Int      @default(3)
  maxContacts Int      @default(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  companies   Company[]
  contacts    Contact[]
  deals       Deal[]
  leads       Lead[]
  tasks       Task[]
  contracts   Contract[]
  offers      Offer[]
  activities  Activity[]
  webhooks    Webhook[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  name           String
  passwordHash   String
  role           String    @default("viewer") // admin, manager, viewer
  avatar         String?
  phone          String?
  department     String?
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  backupCodes    Json      @default("[]")
  calendarToken  String?   @unique
  resetToken     String?
  resetTokenExp  DateTime?
  lastLogin      DateTime?
  loginCount     Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, email])
  @@map("users")
}

// ═══════════════════════════════════════════════════
// WEBHOOKS & AUDIT
// ═══════════════════════════════════════════════════

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url            String
  events         String[] // ["deal.created", "ticket.resolved"]
  secret         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("webhooks")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  action         String   // create, update, delete, login, export
  entityType     String   // company, contact, deal, etc.
  entityId       String?
  entityName     String?
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, entityType])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════
// CRM CORE
// ═══════════════════════════════════════════════════

model Company {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  industry       String?
  website        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  country        String?
  employeeCount  Int?
  annualRevenue  Float?
  description    String?
  status         String   @default("active") // active, inactive, prospect
  category       String   @default("client") // client, partner, prospect, inactive
  leadStatus     String   @default("converted") // new, contacted, qualified, converted, rejected, cancelled
  leadScore      Int      @default(0)
  leadTemperature String? // cold, warm, hot
  userCount      Int      @default(0)
  costCode       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  slaPolicyId    String?
  slaPolicy      SlaPolicy? @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)

  contacts       Contact[]
  deals          Deal[]
  activities     Activity[]
  contracts      Contract[]
  pricingProfiles PricingProfile[]

  @@index([organizationId])
  @@map("companies")
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  fullName       String
  email          String?
  phone          String?
  phones         String[] @default([])
  position       String?
  department     String?
  avatar         String?
  source         String?  // website, referral, cold_call, etc.
  tags           String[] @default([])
  isActive       Boolean  @default(true)
  lastContactAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Portal access
  portalPasswordHash         String?
  portalAccessEnabled        Boolean  @default(false)
  portalLastLoginAt          DateTime?
  portalVerificationToken    String?
  portalVerificationExpires  DateTime?

  activities     Activity[]

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@map("contacts")
}

model Deal {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  contactId      String?
  name           String
  customerNeed   String?
  salesChannel   String?
  stage          String   @default("LEAD")
  valueAmount    Float    @default(0)
  currency       String   @default("AZN")
  probability    Int      @default(0)
  expectedClose  DateTime?
  assignedTo     String?
  lostReason     String?
  notes          String?
  tags           String[] @default([])
  stageChangedAt DateTime?
  confidenceLevel Int      @default(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teamMembers    DealTeamMember[]
  contactRoles   DealContactRole[]

  @@index([organizationId])
  @@index([organizationId, stage])
  @@index([campaignId])
  @@map("deals")
}

model DealContactRole {
  id             String   @id @default(cuid())
  dealId         String
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId      String
  role           String   @default("contact_person")
  influence      String   @default("Medium")
  decisionFactor String   @default("Ease of Use")
  loyalty        String   @default("Neutral")
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([dealId])
  @@map("deal_contact_roles")
}

model DealTeamMember {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([dealId, userId])
  @@index([dealId])
  @@map("deal_team_members")
}

model Lead {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactName    String
  companyName    String?
  email          String?
  phone          String?
  source         String?
  status         String   @default("new") // new, contacted, qualified, converted, lost
  priority       String   @default("medium")
  score          Int      @default(0)
  scoreDetails   Json     @default("{}")
  assignedTo     String?
  estimatedValue Float?
  notes          String?
  convertedAt    DateTime?
  lastScoredAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("leads")
}

model Task {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         String    @default("pending") // pending, in_progress, completed, cancelled
  priority       String    @default("medium")
  dueDate        DateTime?
  assignedTo     String?
  relatedType    String?   // deal, contact, company, lead, ticket
  relatedId      String?
  completedAt    DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([organizationId, assignedTo])
  @@map("tasks")
}

model Contract {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contractNumber String
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
  title          String
  type           String   @default("service_agreement")
  status         String   @default("draft")
  startDate      DateTime?
  endDate        DateTime?
  valueAmount    Float?
  currency       String   @default("AZN")
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  files          ContractFile[]

  @@index([organizationId])
  @@map("contracts")
}

model ContractFile {
  id             String   @id @default(cuid())
  organizationId String
  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fileName       String
  originalName   String
  fileSize       Int
  mimeType       String
  uploadedBy     String?
  createdAt      DateTime @default(now())

  @@index([contractId])
  @@map("contract_files")
}

model Offer {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offerNumber    String
  companyId      String?
  title          String
  status         String   @default("draft")
  totalAmount    Float?
  currency       String   @default("AZN")
  validUntil     DateTime?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("offers")
}

model Activity {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String   // call, email, meeting, note, task
  subject        String?
  description    String?
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id])
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  relatedType    String?
  relatedId      String?
  createdBy      String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, contactId])
  @@map("activities")
}

// ═══════════════════════════════════════════════════
// PIPELINE STAGES (customizable per org)
// ═══════════════════════════════════════════════════

model PipelineStage {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  displayName    String
  color          String   @default("#6366f1")
  probability    Int      @default(0)
  sortOrder      Int      @default(0)
  isWon          Boolean  @default(false)
  isLost         Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("pipeline_stages")
}

// ═══════════════════════════════════════════════════
// COST MODEL & PROFITABILITY
// ═══════════════════════════════════════════════════

model OverheadCost {
  id             String   @id @default(cuid())
  organizationId String
  category       String
  label          String
  amount         Float    @default(0)
  isAnnual       Boolean  @default(false)
  hasVat         Boolean  @default(false)
  isAdmin        Boolean  @default(true)
  targetService  String?  // infosec, permanent_it, cloud, erp, helpdesk, pm, grc
  amortMonths    Int      @default(0)  // 0=no amort, >0=divide amount by this many months (e.g. 60, 84)
  sortOrder      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("overhead_costs")
}

model CostEmployee {
  id             String   @id @default(cuid())
  organizationId String
  department     String   // IT, InfoSec, ERP, PM, HelpDesk, GRC, BackOffice
  position       String
  count          Int      @default(1)
  netSalary      Float    @default(0)
  grossSalary    Float    @default(0)
  superGross     Float    @default(0)
  inOverhead     Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("cost_employees")
}

model PricingParameters {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  totalUsers        Int      @default(0)
  totalEmployees    Int      @default(137)
  technicalStaff    Int      @default(107)
  backOfficeStaff   Int      @default(30)
  monthlyWorkHours  Int      @default(160)
  vatRate           Float    @default(0.18)
  employerTaxRate   Float    @default(0.175)
  riskRate          Float    @default(0.05)
  miscExpenseRate   Float    @default(0.01)
  fixedOverheadRatio Float   @default(0.25)
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("pricing_parameters")
}

model ClientService {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String
  serviceType    String   // permanent_it, infosec, erp, grc, projects, helpdesk, cloud
  monthlyRevenue Float    @default(0)
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, companyId, serviceType])
  @@index([organizationId])
  @@map("client_services")
}

model CostModelSnapshot {
  id                String   @id @default(cuid())
  organizationId    String
  snapshotMonth     String   // "2026-03"
  totalCost         Float    @default(0)
  totalRevenue      Float    @default(0)
  margin            Float    @default(0)
  marginPct         Float    @default(0)
  overheadTotal     Float    @default(0)
  employeeCost      Float    @default(0)
  profitableClients Int      @default(0)
  lossClients       Int      @default(0)
  dataJson          Json     @default("{}")
  createdAt         DateTime @default(now())

  @@unique([organizationId, snapshotMonth])
  @@index([organizationId])
  @@map("cost_model_snapshots")
}

model CostModelLog {
  id             String   @id @default(cuid())
  organizationId String
  tableName      String
  recordId       String?
  action         String   // insert, update, delete
  oldValue       Json?
  newValue       Json?
  changedBy      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("cost_model_logs")
}

// ═══════════════════════════════════════════════════
// SERVICE & SUPPORT
// ═══════════════════════════════════════════════════

model Ticket {
  id             String    @id @default(cuid())
  organizationId String
  ticketNumber   String
  subject        String
  description    String?
  priority       String    @default("medium")
  status         String    @default("new")
  category       String    @default("general")
  contactId      String?
  companyId      String?
  assignedTo     String?
  createdBy      String?
  slaDueAt       DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  satisfactionRating Int?
  satisfactionComment String?
  tags           String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  comments       TicketComment[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, status])
  @@index([organizationId, assignedTo])
  @@map("tickets")
}

model TicketComment {
  id             String   @id @default(cuid())
  ticketId       String
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId         String?
  comment        String
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("ticket_comments")
}

model SlaPolicy {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  priority           String
  firstResponseHours Int
  resolutionHours    Int
  businessHoursOnly  Boolean  @default(true)
  isActive           Boolean  @default(true)
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())

  companies          Company[]

  @@index([organizationId])
  @@map("sla_policies")
}

model KbArticle {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  content        String?
  categoryId     String?
  status         String   @default("draft")
  authorId       String?
  viewCount      Int      @default(0)
  helpfulCount   Int      @default(0)
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("kb_articles")
}

model KbCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  parentId       String?
  sortOrder      Int      @default(0)

  @@index([organizationId])
  @@map("kb_categories")
}

// ═══════════════════════════════════════════════════
// MARKETING & CAMPAIGNS
// ═══════════════════════════════════════════════════

model Campaign {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           String    @default("email")
  status         String    @default("draft")
  subject        String?
  templateId     String?
  segmentId      String?
  recipientMode  String    @default("all")
  recipientIds   Json      @default("[]")
  recipientSource String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  totalRecipients Int      @default(0)
  totalSent      Int       @default(0)
  totalOpened    Int       @default(0)
  totalClicked   Int       @default(0)
  totalBounced   Int       @default(0)
  totalUnsubscribed Int    @default(0)
  totalSpam      Int       @default(0)
  budget         Float     @default(0)
  actualCost     Float     @default(0)
  flowData       Json?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deals          Deal[]

  @@index([organizationId])
  @@map("campaigns")
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  subject        String?
  htmlBody       String?
  textBody       String?
  variables      String[] @default([])
  category       String   @default("general")
  language       String   @default("ru")
  isActive       Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("email_templates")
}

model ContactSegment {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  conditions     Json     @default("{}")
  contactCount   Int      @default(0)
  isDynamic      Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("contact_segments")
}

// ═══════════════════════════════════════════════════
// JOURNEY BUILDER
// ═══════════════════════════════════════════════════

model Journey {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         String   @default("draft")
  triggerType    String
  triggerConditions Json?
  entryCount     Int      @default(0)
  activeCount    Int      @default(0)
  completedCount Int      @default(0)
  conversionCount Int     @default(0)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps          JourneyStep[]

  @@index([organizationId])
  @@map("journeys")
}

model JourneyStep {
  id             String   @id @default(cuid())
  journeyId      String
  journey        Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  stepOrder      Int
  stepType       String
  config         Json?
  yesNextStep    Int?
  noNextStep     Int?
  statsEntered   Int      @default(0)
  statsCompleted Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("journey_steps")
}

model JourneyEnrollment {
  id             String    @id @default(cuid())
  organizationId String
  journeyId      String
  contactId      String?
  leadId         String?
  currentStepId  String?
  status         String    @default("active")
  nextActionAt   DateTime?
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?

  @@index([organizationId])
  @@map("journey_enrollments")
}

// ═══════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  message        String?
  entityType     String?
  entityId       String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId, userId])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════
// AI & PLATFORM
// ═══════════════════════════════════════════════════

model AiAgentConfig {
  id             String   @id @default(cuid())
  organizationId String
  configName     String
  model          String   @default("claude-haiku-4-5-20251001")
  maxTokens      Int      @default(1024)
  temperature    Float    @default(1.0)
  systemPrompt   String?
  toolsEnabled      String[]  @default([])
  escalationEnabled Boolean   @default(true)
  escalationRules   String[]  @default([])
  kbEnabled         Boolean   @default(true)
  kbMaxArticles     Int       @default(3)
  isActive          Boolean   @default(false)
  version           Int       @default(1)
  notes             String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("ai_agent_configs")
}

model AiChatSession {
  id             String   @id @default(cuid())
  organizationId String
  portalUserId   String?
  companyId      String?
  messagesCount  Int      @default(0)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages       AiChatMessage[]

  @@index([organizationId])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id             String   @id @default(cuid())
  sessionId      String
  session        AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role           String   // user, assistant, system
  content        String
  toolCalls      Json?
  tokenCount     Int?
  createdAt      DateTime @default(now())

  @@map("ai_chat_messages")
}

model AiAlert {
  id             String   @id @default(cuid())
  organizationId String
  type           String   // token_spike, high_latency, error, anomaly
  severity       String   @default("warning") // info, warning, critical
  message        String
  sessionId      String?
  metadata       Json?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("ai_alerts")
}

model AiInteractionLog {
  id               String   @id @default(cuid())
  organizationId   String
  sessionId        String?
  userMessage      String
  aiResponse       String
  latencyMs        Float?
  promptTokens     Int?
  completionTokens Int?
  costUsd          Float?
  model            String?
  toolsCalled      String[] @default([])
  kbArticlesUsed   String[] @default([])
  qualityScore     Float?
  isCopilot        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([organizationId])
  @@map("ai_interaction_logs")
}

model AiGuardrail {
  id             String   @id @default(cuid())
  organizationId String
  ruleName       String
  ruleType       String   @default("restriction") // restriction, filter, validation
  description    String?
  promptInjection String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("ai_guardrails")
}

model ChannelConfig {
  id             String   @id @default(cuid())
  organizationId String
  channelType    String   // telegram, whatsapp, email, sms
  configName     String
  botToken       String?
  webhookUrl     String?
  apiKey         String?
  phoneNumber    String?
  settings       Json?
  isActive       Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("channel_configs")
}

model ChannelMessage {
  id              String   @id @default(cuid())
  organizationId  String
  channelConfigId String?
  direction       String   // inbound, outbound
  channelType     String?  // email, telegram, sms, whatsapp
  contactId       String?
  from            String
  to              String
  subject         String?
  body            String
  status          String   @default("delivered") // pending, delivered, failed, read
  externalId      String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, contactId])
  @@map("channel_messages")
}

model EmailLog {
  id             String   @id @default(cuid())
  organizationId String
  direction      String   @default("outbound") // outbound, inbound
  fromEmail      String
  toEmail        String
  subject        String?
  body           String?
  status         String   @default("sent") // pending, sent, delivered, failed, bounced
  errorMessage   String?
  campaignId     String?
  templateId     String?
  contactId      String?
  sentBy         String?
  messageId      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, contactId])
  @@map("email_logs")
}

model WorkflowRule {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  entityType     String
  triggerEvent   String
  conditions     Json     @default("{}")
  isActive       Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())

  actions        WorkflowAction[]

  @@index([organizationId])
  @@map("workflow_rules")
}

model WorkflowAction {
  id             String   @id @default(cuid())
  ruleId         String
  rule           WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  actionType     String
  actionConfig   Json     @default("{}")
  actionOrder    Int      @default(0)

  @@map("workflow_actions")
}

model CustomField {
  id             String   @id @default(cuid())
  organizationId String
  entityType     String
  fieldName      String
  fieldLabel     String
  fieldType      String
  options        String[] @default([])
  isRequired     Boolean  @default(false)
  defaultValue   String?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([organizationId, entityType, fieldName])
  @@index([organizationId])
  @@map("custom_fields")
}

model CustomFieldValue {
  id             String   @id @default(cuid())
  organizationId String
  fieldId        String
  entityId       String
  value          String?

  @@unique([fieldId, entityId])
  @@map("custom_field_values")
}

model Currency {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  symbol         String
  exchangeRate   Float    @default(1.0)
  isBase         Boolean  @default(false)
  isActive       Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, code])
  @@map("currencies")
}

model DashboardLayout {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String   @default("Default")
  layout         Json     @default("[]")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId, userId])
  @@map("dashboard_layouts")
}

// ═══════════════════════════════════════════════════
// PRICING MODULE v2 (PostgreSQL-backed)
// ═══════════════════════════════════════════════════

model PricingGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  profiles       PricingProfile[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("pricing_groups")
}

model PricingProfile {
  id             String   @id @default(cuid())
  organizationId String
  companyCode    String
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  groupId        String
  group          PricingGroup @relation(fields: [groupId], references: [id])
  monthlyTotal   Float    @default(0)
  annualTotal    Float    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categories     PricingProfileCategory[]
  additionalSales AdditionalSale[]

  @@unique([organizationId, companyCode])
  @@index([organizationId])
  @@index([companyId])
  @@map("pricing_profiles")
}

model PricingCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  boardCategory  String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  profileCategories PricingProfileCategory[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("pricing_categories")
}

model PricingProfileCategory {
  id             String   @id @default(cuid())
  organizationId String
  profileId      String
  profile        PricingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoryId     String
  category       PricingCategory @relation(fields: [categoryId], references: [id])
  total          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  services       PricingService[]

  @@unique([profileId, categoryId])
  @@index([organizationId])
  @@map("pricing_profile_categories")
}

model PricingService {
  id                  String   @id @default(cuid())
  organizationId      String
  profileCategoryId   String
  profileCategory     PricingProfileCategory @relation(fields: [profileCategoryId], references: [id], onDelete: Cascade)
  name                String
  unit                String   @default("Per Device")
  qty                 Int      @default(0)
  price               Float    @default(0)
  total               Float    @default(0)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([profileCategoryId])
  @@index([organizationId])
  @@map("pricing_services")
}

model AdditionalSale {
  id             String   @id @default(cuid())
  organizationId String
  profileId      String
  profile        PricingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dealId         String?
  type           String   @default("recurring") // recurring, one_time
  name           String
  description    String?
  categoryName   String?
  unit           String?
  qty            Int      @default(1)
  price          Float    @default(0)
  total          Float    @default(0)
  effectiveDate  DateTime
  endDate        DateTime?
  status         String   @default("active") // active, cancelled, completed
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([profileId])
  @@index([dealId])
  @@map("additional_sales")
}

model Event {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           String   @default("conference") // conference, webinar, workshop, meetup, exhibition, other
  status         String   @default("planned")    // planned, registration_open, in_progress, completed, cancelled
  startDate      DateTime
  endDate        DateTime?
  location       String?
  isOnline       Boolean  @default(false)
  meetingUrl     String?
  budget         Float    @default(0)
  actualCost     Float    @default(0)
  expectedRevenue Float   @default(0)
  actualRevenue  Float    @default(0)
  maxParticipants Int?
  registeredCount Int     @default(0)
  attendedCount   Int     @default(0)
  responsibleId  String?
  tags           String[] @default([])
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participants   EventParticipant[]

  @@index([organizationId])
  @@map("events")
}

model EventParticipant {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contactId      String?
  companyId      String?
  name           String
  email          String?
  phone          String?
  role           String   @default("attendee") // attendee, speaker, sponsor, organizer, vip
  status         String   @default("registered") // registered, confirmed, attended, cancelled, no_show
  source         String   @default("invited")    // invited, self_registered, imported
  invitedAt      DateTime?
  inviteStatus   String   @default("not_sent")   // not_sent, sent, opened, declined
  registeredAt   DateTime @default(now())
  notes          String?

  @@index([eventId])
  @@map("event_participants")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       String   @default("service")  // service, product, addon, consulting
  price          Float    @default(0)
  currency       String   @default("AZN")
  isActive       Boolean  @default(true)
  features       String[] @default([])
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("products")
}

