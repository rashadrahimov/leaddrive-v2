// INVOICES & BILLING
// ═══════════════════════════════════════════════════

model Invoice {
  id                String    @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber     String
  dealId            String?
  deal              Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  companyId         String?
  company           Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId         String?
  contact           Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contractId        String?
  contract          Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  offerId           String?

  title             String
  status            String    @default("draft") // draft, sent, viewed, partially_paid, paid, overdue, cancelled, refunded

  // Financial
  subtotal          Float     @default(0)
  discountType      String    @default("percentage") // percentage, fixed
  discountValue     Float     @default(0)
  discountAmount    Float     @default(0)
  taxRate           Float     @default(0)
  taxAmount         Float     @default(0)
  totalAmount       Float     @default(0)
  paidAmount        Float     @default(0)
  balanceDue        Float     @default(0)
  currency          String    @default("AZN")

  // Tax details
  voen              String?
  sellerVoen        String?
  includeVat        Boolean   @default(false)

  // Dates
  issueDate         DateTime  @default(now())
  dueDate           DateTime?
  sentAt            DateTime?
  viewedAt          DateTime?
  paidAt            DateTime?

  // Payment terms
  paymentTerms      String    @default("net30")
  paymentTermsDays  Int?

  // Recipient
  recipientEmail    String?
  recipientName     String?
  billingAddress    String?

  // Notes
  notes             String?
  termsAndConditions String?
  footerNote        String?

  // Document details
  signerName        String?
  signerTitle       String?
  contractNumber    String?
  contractDate      String?
  documentLanguage  String    @default("az")

  // Recurring
  recurringInvoiceId String?
  recurringInvoice   RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])

  // Communication chain
  chainJourneyId    String?   // dedicated Journey for this invoice's reminder chain

  // Custom columns definition
  customColumns     Json?     // [{ "key": "unit", "label": "Ölçü vahidi" }, ...]

  // Meta
  viewToken         String?   @unique
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items             InvoiceItem[]
  payments          InvoicePayment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, companyId])
  @@index([dealId])
  @@index([contractId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  name        String
  description String?
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  discount    Float   @default(0)
  taxRate     Float?
  total       Float   @default(0)
  sortOrder   Int     @default(0)
  customFields Json?  // { "columnName": "value", ... }

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Float
  currency       String   @default("AZN")
  paymentMethod  String   @default("bank_transfer")
  paymentDate    DateTime @default(now())
  reference      String?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())

  @@index([invoiceId])
  @@index([organizationId])
  @@map("invoice_payments")
}

model RecurringInvoice {
  id                String    @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title             String
  titleTemplate     String?   // e.g. "IT Xidmətləri — {month} {year}"
  companyId         String?
  contactId         String?
  dealId            String?
  contractId        String?

  frequency         String    @default("monthly")
  intervalCount     Int       @default(1)
  startDate         DateTime
  endDate           DateTime?
  nextRunDate       DateTime?
  lastRunDate       DateTime?
  totalGenerated    Int       @default(0)
  maxOccurrences    Int?

  currency          String    @default("AZN")
  taxRate           Float     @default(0)
  includeVat        Boolean   @default(false)
  voen              String?
  paymentTerms      String    @default("net30")
  notes             String?
  termsAndConditions String?
  recipientEmail    String?

  autoSend          Boolean   @default(false)
  dayOfMonth        Int?      // e.g. 25 = generate on 25th

  isActive          Boolean   @default(true)
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items             RecurringInvoiceItem[]
  invoices          Invoice[]

  @@index([organizationId])
  @@index([organizationId, nextRunDate])
  @@map("recurring_invoices")
}

model RecurringInvoiceItem {
  id                  String  @id @default(cuid())
  recurringInvoiceId  String
  recurringInvoice    RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
  productId           String?
  name                String
  description         String?
  quantity            Float   @default(1)
  unitPrice           Float   @default(0)
  discount            Float   @default(0)
  sortOrder           Int     @default(0)
  customFields        Json?

  @@index([recurringInvoiceId])
  @@map("recurring_invoice_items")
}

// ═══════════════════════════════════════════════════
// BUDGETING
// ═══════════════════════════════════════════════════

model BudgetCostType {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key              String   // machine key: "labor", "overhead_admin", etc.
  label            String   // user-facing: "ФОТ (зарплаты)"
  costModelPattern String?  // template: "serviceDetails.{dept}.directLabor"
  isShared         Boolean  @default(false)  // true = not split by department (backoffice, risk)
  allocationMethod String?  // "proportional" | "fixed" | null
  color            String?  // hex color for UI
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  budgetLines      BudgetLine[]
  budgetActuals    BudgetActual[]
  forecastEntries  BudgetForecastEntry[]
  directionTemplates BudgetDirectionTemplate[]
  expenseForecasts   ExpenseForecast[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("budget_cost_types")
}

model BudgetDepartment {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String   // machine key: "it", "infosec", etc.
  label          String   // user-facing: "Daimi IT", "InfoSec"
  serviceKey     String?  // cost model service key: "permanent_it", "infosec"
  hasRevenue     Boolean  @default(true)  // false for BackOffice
  color          String?  // hex color for UI
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  budgetLines      BudgetLine[]
  budgetActuals    BudgetActual[]
  forecastEntries  BudgetForecastEntry[]
  directionTemplates BudgetDirectionTemplate[]
  salesForecasts     SalesForecast[]
  expenseForecasts   ExpenseForecast[]
  owners             BudgetDepartmentOwner[]

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("budget_departments")
}

model BudgetPlan {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  periodType     String   @default("monthly")  // monthly | quarterly | annual
  year           Int
  month          Int?
  quarter        Int?
  status         String   @default("draft")    // draft | pending_approval | approved | rejected | closed
  notes          String?
  submittedBy    String?
  submittedAt    DateTime?
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  amendmentOf    String?  // ID of plan this amends (version chain root)
  version        Int      @default(1)
  versionLabel   String?  // "v1", "v2 (Q1 revision)"
  snapshotData   Json?    // full snapshot for versioning: { lines: [...] }
  isRolling      Boolean  @default(false)
  rollingMonths  Int      @default(12)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines             BudgetLine[]
  actuals           BudgetActual[]
  sections          BudgetSection[]
  forecastEntries   BudgetForecastEntry[]
  approvalComments     BudgetApprovalComment[]
  accountingImports    AccountingImport[]
  rollingForecastMonths RollingForecastMonth[]

  @@index([organizationId])
  @@map("budget_plans")
}

model BudgetLine {
  id             String   @id @default(cuid())
  organizationId String
  planId         String
  plan           BudgetPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  category       String
  department     String?
  lineType       String   @default("expense")  // expense | revenue | cogs
  lineSubtype    String?  // service | product | cogs | null
  plannedAmount  Float    @default(0)
  forecastAmount Float?
  unitPrice      Float?   // For product lines: price per unit
  unitCost       Float?   // For COGS: cost per unit
  quantity       Int?     // For product/COGS: number of units
  costModelKey   String?  // e.g. "grandTotalG", "deptCosts.IT", "serviceRevenues.total"
  isAutoPlanned  Boolean  @default(true)   // true = план из cost model + SalesForecast
  isAutoActual   Boolean  @default(false)
  costTypeId     String?
  costType       BudgetCostType? @relation(fields: [costTypeId], references: [id], onDelete: SetNull)
  departmentId   String?
  budgetDept     BudgetDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  vatIncluded    Boolean  @default(false) // true = amount includes VAT
  vatRate        Float?   // e.g. 0.18 for 18% — null means no VAT applicable
  amountExVat    Float?   // computed: plannedAmount / (1 + vatRate) when vatIncluded=true
  currencyCode   String?  // "USD", "EUR", null = base currency
  exchangeRate   Float?   // rate at time of entry (e.g. 1.70 for 1 USD = 1.70 AZN)
  originalAmount Float?   // amount in original currency
  notes          String?
  sortOrder      Int      @default(0)
  parentId       String?
  parent         BudgetLine?  @relation("LineChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       BudgetLine[] @relation("LineChildren")

  @@index([organizationId])
  @@index([planId])
  @@index([parentId])
  @@index([costTypeId])
  @@index([departmentId])
  @@map("budget_lines")
}

model BudgetActual {
  id             String   @id @default(cuid())
  organizationId String
  planId         String
  plan           BudgetPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  category       String
  department     String?
  lineType       String   @default("expense")
  actualAmount   Float    @default(0)
  expenseDate    String?
  description    String?
  currencyCode   String?  // "USD", "EUR", null = base currency
  exchangeRate   Float?   // rate at time of entry
  originalAmount Float?   // amount in original currency
  costTypeId     String?
  costType       BudgetCostType? @relation(fields: [costTypeId], references: [id], onDelete: SetNull)
  departmentId   String?
  budgetDept     BudgetDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([planId])
  @@index([costTypeId])
  @@index([departmentId])
  @@map("budget_actuals")
}

model BudgetSection {
  id             String   @id @default(cuid())
  organizationId String
  planId         String
  plan           BudgetPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name           String
  sectionType    String   @default("expense") // revenue | expense | gross_profit | ebitda
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([planId])
  @@map("budget_sections")
}

model BudgetForecastEntry {
  id             String   @id @default(cuid())
  organizationId String
  planId         String
  plan           BudgetPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  month          Int
  year           Int
  category       String
  lineType       String   @default("expense")
  forecastAmount Float    @default(0)
  costTypeId     String?
  costType       BudgetCostType? @relation(fields: [costTypeId], references: [id], onDelete: SetNull)
  departmentId   String?
  budgetDept     BudgetDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([planId, year, month, category, lineType])
  @@index([organizationId])
  @@index([planId])
  @@index([costTypeId])
  @@index([departmentId])
  @@map("budget_forecast_entries")
}

model BudgetDirectionTemplate {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  lineType        String   @default("revenue")  // revenue | expense | cogs
  lineSubtype     String?  // service | product | cogs
  defaultAmount   Float    @default(0)
  unitPrice       Float?
  unitCost        Float?
  quantity         Int?
  costModelKey    String?
  department      String?
  costTypeId      String?
  costType        BudgetCostType? @relation(fields: [costTypeId], references: [id], onDelete: SetNull)
  departmentId    String?
  budgetDept      BudgetDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([costTypeId])
  @@index([departmentId])
  @@map("budget_direction_templates")
}

model SalesForecast {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId    String
  budgetDept      BudgetDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  year            Int
  month           Int      // 1-12
  amount          Float    @default(0)  // monthly revenue forecast (excl. VAT, AZN)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, departmentId, year, month])
  @@index([organizationId])
  @@index([organizationId, year])
  @@map("sales_forecasts")
}

model ExpenseForecast {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  costTypeId      String
  budgetCostType  BudgetCostType @relation(fields: [costTypeId], references: [id], onDelete: Cascade)
  departmentId    String?
  budgetDept      BudgetDepartment? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  year            Int
  month           Int      // 1-12
  amount          Float    @default(0)  // monthly expense forecast (AZN)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, year])
  @@index([organizationId, costTypeId, departmentId, year, month])
  @@map("expense_forecasts")
}

// ═══════════════════════════════════════════════════
// BUDGET ACCESS CONTROL & APPROVAL
// ═══════════════════════════════════════════════════

model BudgetDepartmentOwner {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String
  budgetDept     BudgetDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  canEdit        Boolean          @default(true)
  canApprove     Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@unique([organizationId, departmentId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("budget_department_owners")
}

model BudgetApprovalComment {
  id             String     @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String
  plan           BudgetPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  status         String     // submitted | review | approved | rejected | comment
  comment        String
  createdAt      DateTime   @default(now())

  @@index([planId, createdAt])
  @@index([organizationId])
  @@map("budget_approval_comments")
}

model SocialConversation {
  id              String   @id @default(cuid())
  organizationId  String
  channelConfigId String?
  platform        String   // whatsapp | telegram | facebook | instagram | vkontakte | email | sms
  externalId      String   // platform-specific thread ID
  contactId       String?
  contactName     String   @default("")
  contactAvatar   String?
  status          String   @default("open")  // open | resolved | archived
  unreadCount     Int      @default(0)
  lastMessage     String   @default("")
  lastMessageAt   DateTime @default(now())
  assignedTo      String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        ChannelMessage[]
  organization    Organization     @relation(fields: [organizationId], references: [id])
  channelConfig   ChannelConfig?   @relation(fields: [channelConfigId], references: [id])

  @@unique([organizationId, platform, externalId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, lastMessageAt])
  @@map("social_conversations")
}

// ═══════════════════════════════════════════════════
// PROJECT MANAGEMENT (ERP Module)
// ═══════════════════════════════════════════════════

model Project {
  id                   String    @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                 String
  code                 String?   // e.g. "PRJ-001"
  description          String?
  status               String    @default("planning") // planning, active, on_hold, completed, cancelled
  priority             String    @default("medium")   // low, medium, high, critical
  startDate            DateTime?
  endDate              DateTime?
  actualStartDate      DateTime?
  actualEndDate        DateTime?
  budget               Float     @default(0)
  actualCost           Float     @default(0)
  currency             String    @default("AZN")
  completionPercentage Int       @default(0)
  managerId            String?   // userId of project manager
  companyId            String?
  company              Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  dealId               String?
  color                String    @default("#6366f1")
  tags                 String[]  @default([])
  createdBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  members              ProjectMember[]
  milestones           ProjectMilestone[]
  tasks                ProjectTask[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([companyId])
  @@map("projects")
}

model ProjectMember {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId         String
  role           String   @default("member") // manager, member, viewer
  hourlyRate     Float?   @default(0)
  hoursLogged    Float    @default(0)
  joinedAt       DateTime @default(now())

  @@unique([projectId, userId])
  @@index([organizationId])
  @@index([projectId])
  @@map("project_members")
}

model ProjectMilestone {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  dueDate        DateTime?
  completedAt    DateTime?
  status         String    @default("pending") // pending, in_progress, completed, overdue
  color          String    @default("#6366f1")
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())

  tasks          ProjectTask[]

  @@index([projectId])
  @@index([organizationId])
  @@map("project_milestones")
}

model ProjectTask {
  id              String    @id @default(cuid())
  organizationId  String
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId     String?
  milestone       ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  parentId        String?
  parent          ProjectTask?  @relation("SubTasks", fields: [parentId], references: [id], onDelete: SetNull)
  children        ProjectTask[] @relation("SubTasks")
  title           String
  description     String?
  status          String    @default("todo") // todo, in_progress, review, done, cancelled
  priority        String    @default("medium")
  assignedTo      String?
  dueDate         DateTime?
  estimatedHours  Float?    @default(0)
  actualHours     Float     @default(0)
  completedAt     DateTime?
  sortOrder       Int       @default(0)
  tags            String[]  @default([])
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@index([organizationId])
  @@index([milestoneId])
  @@index([parentId])
  @@index([organizationId, assignedTo])
  @@map("project_tasks")
}

// ═══════════════════════════════════════════════════
// FINANCE MODULE (A/P, Funds)
// ═══════════════════════════════════════════════════

model Bill {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billNumber     String
  vendorName     String
  vendorId       String?
  vendor         Company?  @relation("VendorBills", fields: [vendorId], references: [id], onDelete: SetNull)
  title          String
  status         String    @default("draft") // draft, pending, partially_paid, paid, overdue, cancelled
  totalAmount    Float     @default(0)
  paidAmount     Float     @default(0)
  balanceDue     Float     @default(0)
  currency       String    @default("AZN")
  issueDate      DateTime  @default(now())
  dueDate        DateTime?
  paidAt         DateTime?
  category       String?   // "rent", "software", "services", "equipment"
  notes          String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  payments       BillPayment[]

  @@unique([organizationId, billNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, vendorId])
  @@map("bills")
}

model BillPayment {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billId         String
  bill           Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount         Float
  currency       String   @default("AZN")
  paymentMethod  String   @default("bank_transfer")
  paymentDate    DateTime @default(now())
  reference      String?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())

  @@index([billId])
  @@index([organizationId])
  @@map("bill_payments")
}

model Fund {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String   // "Tax Reserve", "Payroll Buffer", "Emergency", "Dividends"
  description    String?
  targetAmount   Float?
  currentBalance Float    @default(0)
  currency       String   @default("AZN")
  color          String?
  isActive       Boolean  @default(true)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions   FundTransaction[]
  rules          FundRule[]

  @@index([organizationId])
  @@map("funds")
}

model FundTransaction {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fundId         String
  fund           Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  type           String   // "deposit" | "withdrawal" | "transfer_in" | "transfer_out" | "auto_allocation"
  amount         Float
  description    String?
  relatedType    String?  // "invoice_payment", "manual", "rule"
  relatedId      String?
  createdBy      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([fundId])
  @@map("fund_transactions")
}

model FundRule {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fundId         String
  fund           Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  name           String
  triggerType    String   // "revenue_percentage" | "fixed_monthly" | "invoice_paid"
  percentage     Float?   // for revenue_percentage: 0.10 = 10%
  fixedAmount    Float?   // for fixed_monthly
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([fundId])
  @@map("fund_rules")
}

// ============================================================
// MTM (Mobile Team Management) Models
