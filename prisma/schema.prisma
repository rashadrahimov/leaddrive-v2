// LeadDrive CRM v2.0 — Prisma Schema
// Multi-tenant: ALL models (except Organization) have organizationId

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ORGANIZATION & AUTH
// ═══════════════════════════════════════════════════

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("starter") // starter, professional, enterprise
  addons      String[] @default([])
  modules     Json     @default("{}")
  logo        String?
  settings    Json     @default("{}")
  maxUsers    Int      @default(3)
  maxContacts Int      @default(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  companies   Company[]
  contacts    Contact[]
  deals       Deal[]
  leads       Lead[]
  tasks       Task[]
  contracts   Contract[]
  offers      Offer[]
  activities  Activity[]
  webhooks    Webhook[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]

  planRequests PlanRequest[]
  invoices          Invoice[]
  invoicePayments   InvoicePayment[]
  recurringInvoices RecurringInvoice[]
  budgetPlans       BudgetPlan[]
  budgetCostTypes   BudgetCostType[]
  budgetDepartments BudgetDepartment[]
  socialConversations SocialConversation[]
  salesForecasts     SalesForecast[]
  expenseForecasts   ExpenseForecast[]
  projects           Project[]
  budgetDeptOwners   BudgetDepartmentOwner[]
  budgetApprovalComments BudgetApprovalComment[]
  currencyRateHistory    CurrencyRateHistory[]
  accountingIntegrations AccountingIntegration[]
  accountingImports      AccountingImport[]
  rollingForecastMonths  RollingForecastMonth[]
  cashFlowEntries        CashFlowEntry[]
  cashFlowAlerts         CashFlowAlert[]
  bills                  Bill[]
  billPayments           BillPayment[]
  funds                  Fund[]
  fundTransactions       FundTransaction[]
  fundRules              FundRule[]
  pipelines              Pipeline[]

  // MTM (Mobile Team Management) relations
  mtmAgents              MtmAgent[]
  mtmCustomers           MtmCustomer[]
  mtmRoutes              MtmRoute[]
  mtmVisits              MtmVisit[]
  mtmTasks               MtmTask[]
  mtmPhotos              MtmPhoto[]
  mtmAlerts              MtmAlert[]
  mtmAgentLocations      MtmAgentLocation[]
  mtmOrders              MtmOrder[]
  mtmSettings            MtmSetting[]
  mtmNotifications       MtmNotification[]
  mtmAuditLogs           MtmAuditLog[]
  leadAssignmentRules    LeadAssignmentRule[]

  @@map("organizations")
}

model PlanRequest {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedPlan  String
  contactName    String
  contactEmail   String
  contactPhone   String?
  message        String?
  status         String   @default("pending") // pending, approved, rejected
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("plan_requests")
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  name           String
  passwordHash   String
  role           String    @default("viewer") // admin, manager, sales, support, viewer
  avatar         String?
  phone          String?
  department     String?
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  require2fa     Boolean   @default(false)
  backupCodes    Json      @default("[]")
  calendarToken  String?   @unique
  twoFactorNonce    String?   // Server-side nonce for secure 2FA session update
  passwordChangedAt DateTime? // Track password changes for session invalidation
  resetToken     String?
  resetTokenExp  DateTime?
  lastLogin      DateTime?
  loginCount     Int       @default(0)
  isActive       Boolean   @default(true)
  skills         String[]  @default([])
  maxTickets     Int       @default(20)
  isAvailable    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  budgetDeptOwnership BudgetDepartmentOwner[]
  mtmAgents           MtmAgent[]
  accounts            Account[]

  @@unique([organizationId, email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String  // "oauth" | "credentials"
  provider          String  // "google" | "microsoft-entra-id" | "credentials"
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ═══════════════════════════════════════════════════
// WEBHOOKS & AUDIT
// ═══════════════════════════════════════════════════

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url            String
  events         String[] // ["deal.created", "ticket.resolved"]
  secret         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("webhooks")
}

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  keyHash        String
  keyPrefix      String    // first 8 chars for display "ld_abc12..."
  scopes         String[]  // ["read:companies", "write:deals", "read:contacts"]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("api_keys")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  action         String   // create, update, delete, login, export
  entityType     String   // company, contact, deal, etc.
  entityId       String?
  entityName     String?
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, entityType])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════
// CRM CORE
// ═══════════════════════════════════════════════════

model Company {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  industry       String?
  website        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  country        String?
  employeeCount  Int?
  annualRevenue  Float?
  description    String?
  status         String   @default("active") // active, inactive, prospect
  category       String   @default("client") // client, partner, prospect, inactive
  leadStatus     String   @default("converted") // new, contacted, qualified, converted, rejected, cancelled
  leadScore      Int      @default(0)
  leadTemperature String? // cold, warm, hot
  userCount      Int      @default(0)
  costCode       String?
  voen           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  slaPolicyId    String?
  slaPolicy      SlaPolicy? @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)

  contacts       Contact[]
  deals          Deal[]
  activities     Activity[]
  contracts      Contract[]
  invoices       Invoice[]
  pricingProfiles PricingProfile[]
  projects       Project[]
  tickets        Ticket[]
  vendorBills    Bill[]   @relation("VendorBills")

  @@index([organizationId])
  @@map("companies")
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  fullName       String
  email          String?
  phone          String?
  phones         String[] @default([])
  position       String?
  department     String?
  avatar         String?
  source         String?  // website, referral, cold_call, etc.
  tags           String[] @default([])
  isActive       Boolean  @default(true)
  lastContactAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Portal access
  portalPasswordHash         String?
  portalAccessEnabled        Boolean  @default(false)
  portalLastLoginAt          DateTime?
  portalVerificationToken    String?
  portalVerificationExpires  DateTime?

  activities     Activity[]
  invoices       Invoice[]
  tickets        Ticket[]

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@map("contacts")
}

model Deal {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contactId      String?
  pipelineId     String?
  pipeline       Pipeline? @relation(fields: [pipelineId], references: [id])
  name           String
  customerNeed   String?
  salesChannel   String?
  stage          String   @default("LEAD")
  valueAmount    Float    @default(0)
  currency       String   @default("AZN")
  probability    Int      @default(0)
  expectedClose  DateTime?
  assignedTo     String?
  lostReason     String?
  notes          String?
  tags           String[] @default([])
  stageChangedAt DateTime?
  confidenceLevel Int      @default(50)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teamMembers    DealTeamMember[]
  contactRoles   DealContactRole[]
  competitors    DealCompetitor[]
  offers         Offer[]
  invoices       Invoice[]

  @@index([organizationId])
  @@index([organizationId, stage])
  @@index([campaignId])
  @@index([pipelineId])
  @@map("deals")
}

model DealContactRole {
  id             String   @id @default(cuid())
  dealId         String
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId      String
  role           String   @default("contact_person")
  influence      String   @default("Medium")
  decisionFactor String   @default("Ease of Use")
  loyalty        String   @default("Neutral")
  isPrimary      Boolean  @default(false)
  cashbackType   String?  // "percent" or "fixed"
  cashbackValue  Float?   // percentage (e.g. 5.0) or fixed amount
  createdAt      DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([dealId])
  @@map("deal_contact_roles")
}

model DealCompetitor {
  id          String   @id @default(cuid())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  name        String
  product     String?
  strengths   String?
  weaknesses  String?
  price       String?
  threat      String   @default("Medium") // High, Medium, Low
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([dealId, name])
  @@index([dealId])
  @@map("deal_competitors")
}

model DealTeamMember {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([dealId, userId])
  @@index([dealId])
  @@map("deal_team_members")
}

model Lead {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactName    String
  companyName    String?
  email          String?
  phone          String?
  source         String?
  status         String   @default("new") // new, contacted, qualified, converted, lost
  priority       String   @default("medium")
  score          Int      @default(0)
  scoreDetails   Json     @default("{}")
  assignedTo     String?
  estimatedValue Float?
  notes          String?
  convertedAt    DateTime?
  lastScoredAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("leads")
}

model Task {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         String    @default("pending") // pending, in_progress, completed, cancelled
  priority       String    @default("medium")
  dueDate        DateTime?
  assignedTo     String?
  relatedType    String?   // deal, contact, company, lead, ticket
  relatedId      String?
  completedAt    DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([organizationId, assignedTo])
  @@map("tasks")
}

model Contract {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contractNumber String
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  title          String
  type           String   @default("service_agreement")
  status         String   @default("draft")
  startDate      DateTime?
  endDate        DateTime?
  valueAmount    Float?
  currency       String   @default("AZN")
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  files          ContractFile[]
  invoices       Invoice[]

  @@index([organizationId])
  @@map("contracts")
}

model ContractFile {
  id             String   @id @default(cuid())
  organizationId String
  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fileName       String
  originalName   String
  fileSize       Int
  mimeType       String
  uploadedBy     String?
  createdAt      DateTime @default(now())

  @@index([contractId])
  @@map("contract_files")
}

model Offer {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offerNumber    String
  dealId         String?
  deal           Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  companyId      String?
  contactId      String?
  type           String   @default("commercial") // commercial, invoice, equipment, services
  title          String
  status         String   @default("draft") // draft, sent, approved, rejected
  totalAmount    Float?
  currency       String   @default("AZN")
  clientName     String?
  voen           String?
  contactPerson  String?
  contractNumber String?
  includeVat     Boolean  @default(false)
  discount       Float?   @default(0)
  validUntil     DateTime?
  notes          String?
  recipientEmail String?
  sentAt         DateTime?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          OfferItem[]

  @@index([organizationId])
  @@index([dealId])
  @@map("offers")
}

model OfferItem {
  id        String @id @default(cuid())
  offerId   String
  offer     Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  productId String?
  name      String
  quantity  Int    @default(1)
  unitPrice Float  @default(0)
  discount  Float  @default(0)
  total     Float  @default(0)
  sortOrder Int    @default(0)

  @@index([offerId])
  @@map("offer_items")
}

model Activity {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String   // call, email, meeting, note, task
  subject        String?
  description    String?
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  relatedType    String?
  relatedId      String?
  createdBy      String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, contactId])
  @@map("activities")
}

// ═══════════════════════════════════════════════════
// PIPELINES & STAGES (customizable per org)
// ═══════════════════════════════════════════════════

model Pipeline {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isDefault      Boolean         @default(false)
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())

  stages         PipelineStage[]
  deals          Deal[]

  @@index([organizationId])
  @@map("pipelines")
}

model PipelineStage {
  id             String    @id @default(cuid())
  organizationId String
  pipelineId     String?
  pipeline       Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name           String
  displayName    String
  color          String    @default("#6366f1")
  probability    Int       @default(0)
  sortOrder      Int       @default(0)
  isWon          Boolean   @default(false)
  isLost         Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  validationRules StageValidationRule[]

  @@index([organizationId])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

model StageValidationRule {
  id              String        @id @default(cuid())
  organizationId  String
  pipelineStageId String
  stage           PipelineStage @relation(fields: [pipelineStageId], references: [id], onDelete: Cascade)
  fieldName       String        // "valueAmount", "contactId", "notes", "expectedClose"
  ruleType        String        // "required", "min_value", "file_attached", "task_completed"
  ruleValue       String?       // e.g. "1000" for min_value
  errorMessage    String        // Human-readable error
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())

  @@index([organizationId])
  @@index([pipelineStageId])
  @@map("stage_validation_rules")
}

// ═══════════════════════════════════════════════════
// COST MODEL & PROFITABILITY
// ═══════════════════════════════════════════════════

model OverheadCost {
  id             String   @id @default(cuid())
  organizationId String
  category       String
  label          String
  amount         Float    @default(0)
  isAnnual       Boolean  @default(false)
  hasVat         Boolean  @default(false)
  isAdmin        Boolean  @default(true)
  targetService  String?  // infosec, permanent_it, cloud, erp, helpdesk, pm, grc
  amortMonths    Int      @default(0)  // 0=no amort, >0=divide amount by this many months (e.g. 60, 84)
  sortOrder      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("overhead_costs")
}

model CostEmployee {
  id             String   @id @default(cuid())
  organizationId String
  department     String   // IT, InfoSec, ERP, PM, HelpDesk, GRC, BackOffice
  position       String
  count          Int      @default(1)
  netSalary      Float    @default(0)
  grossSalary    Float    @default(0)
  superGross     Float    @default(0)
  inOverhead     Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("cost_employees")
}

model PricingParameters {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  totalUsers        Int      @default(0)
  totalEmployees    Int      @default(137)
  technicalStaff    Int      @default(107)
  backOfficeStaff   Int      @default(30)
  monthlyWorkHours  Int      @default(160)
  vatRate           Float    @default(0.18)
  employerTaxRate   Float    @default(0.175)
  riskRate          Float    @default(0.05)
  miscExpenseRate   Float    @default(0.01)
  fixedOverheadRatio Float   @default(0.25)
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  @@map("pricing_parameters")
}

model ClientService {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String
  serviceType    String   // permanent_it, infosec, erp, grc, projects, helpdesk, cloud
  monthlyRevenue Float    @default(0)
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, companyId, serviceType])
  @@index([organizationId])
  @@map("client_services")
}

model CostModelSnapshot {
  id                String   @id @default(cuid())
  organizationId    String
  snapshotMonth     String   // "2026-03"
  totalCost         Float    @default(0)
  totalRevenue      Float    @default(0)
  margin            Float    @default(0)
  marginPct         Float    @default(0)
  overheadTotal     Float    @default(0)
  employeeCost      Float    @default(0)
  profitableClients Int      @default(0)
  lossClients       Int      @default(0)
  dataJson          Json     @default("{}")
  createdAt         DateTime @default(now())

  @@unique([organizationId, snapshotMonth])
  @@index([organizationId])
  @@map("cost_model_snapshots")
}

model CostModelLog {
  id             String   @id @default(cuid())
  organizationId String
  tableName      String
  recordId       String?
  action         String   // insert, update, delete
  oldValue       Json?
  newValue       Json?
  changedBy      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("cost_model_logs")
}

model BudgetChangeLog {
  id             String   @id @default(cuid())
  organizationId String
  planId         String
  entityType     String   // "line" | "actual" | "forecast"
  entityId       String
  action         String   // "create" | "update" | "delete"
  field          String?  // null for create/delete, field name for update
  oldValue       Json?
  newValue       Json?
  snapshot       Json?    // full entity state after this change
  userId         String?
  createdAt      DateTime @default(now())

  @@index([planId, createdAt])
  @@index([organizationId])
  @@map("budget_change_logs")
}

// ═══════════════════════════════════════════════════
// SERVICE & SUPPORT
// ═══════════════════════════════════════════════════

model Ticket {
  id             String    @id @default(cuid())
  organizationId String
  ticketNumber   String
  subject        String
  description    String?
  priority       String    @default("medium")
  status         String    @default("new")
  category       String    @default("general")
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedTo     String?
  createdBy      String?
  slaDueAt              DateTime?
  slaFirstResponseDueAt DateTime?
  slaPolicyName         String?
  firstResponseAt       DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  satisfactionRating Int?
  satisfactionComment String?
  tags              String[]  @default([])
  escalationLevel   Int       @default(0)
  lastEscalatedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  comments       TicketComment[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, status])
  @@index([organizationId, assignedTo])
  @@map("tickets")
}

model TicketComment {
  id             String   @id @default(cuid())
  ticketId       String
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId         String?
  comment        String
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("ticket_comments")
}

model TicketQueue {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  skills         String[]
  priority       Int      @default(0)
  autoAssign     Boolean  @default(true)
  assignMethod   String   @default("least_loaded") // "least_loaded" | "round_robin"
  lastAssignedTo String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@map("ticket_queues")
}

model EscalationRule {
  id              String   @id @default(cuid())
  organizationId  String
