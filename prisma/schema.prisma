  INACTIVE
  SUSPENDED
}

enum MtmCustomerCategory {
  A
  B
  C
  D
}

enum MtmCustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum MtmRouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
