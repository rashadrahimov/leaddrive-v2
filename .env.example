# Database
DATABASE_URL="postgresql://leaddrive:leaddrive@localhost:5432/leaddrive"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Domain URLs (production: app.leaddrivecrm.org / leaddrivecrm.org)
NEXT_PUBLIC_APP_URL=""
NEXT_PUBLIC_MARKETING_URL=""

# Cookie domain (e.g. ".leaddrivecrm.org" — must start with dot for subdomain sharing)
COOKIE_DOMAIN=""

# Contact email shown on marketing pages and used for notifications
NEXT_PUBLIC_CONTACT_EMAIL=""

# CNAME target for custom domains feature
CNAME_TARGET=""

# Base domain for tenant subdomains (e.g. "leaddrivecrm.org" → {slug}.leaddrivecrm.org)
NEXT_PUBLIC_BASE_DOMAIN="leaddrivecrm.org"

# Cloudflare API (for tenant DNS automation)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# Shared server IP for tenant DNS records (default: 46.224.171.53)
SHARED_SERVER_IP="46.224.171.53"

# Cron job secret (for /api/cron/* endpoints)
CRON_SECRET=""

# Google OAuth (optional — for SSO login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft / Azure AD OAuth (optional — for SSO login)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# Compute Service (FastAPI)
COMPUTE_SERVICE_URL="http://localhost:8000"

# AI
ANTHROPIC_API_KEY=""

# WhatsApp Cloud API — DEPRECATED ENV VARS
#
# All WhatsApp credentials are per-tenant and stored in ChannelConfig.
# Tenants configure their own WABA via /settings/channels +
# /settings/channels/whatsapp.
#
# These env vars are read only by the LeadDrive tenant's backfill script
# (scripts/migrate-leaddrive-whatsapp.mjs) during the transition, and by
# the webhook's legacy fallback when ?t= is not present in the callback URL.
# Remove them after every tenant's ChannelConfig is populated and every Meta
# app points to /api/v1/webhooks/whatsapp?t={slug}.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN="leaddrive-whatsapp-verify-2026"
# WHATSAPP_APP_SECRET=""     # per-tenant; store in ChannelConfig.appSecret

# Stripe (Phase 6)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
